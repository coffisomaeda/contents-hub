# Supabase（ブラウザに公開してよい値）
PUBLIC_SUPABASE_URL=https://your-project.supabase.co
PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# AI アシスタント（サーバー側専用 / ブラウザに露出させない）
# Google AI Studio (https://aistudio.google.com/apikey) で取得
GEMINI_API_KEY=your-gemini-api-key
# AI_API_KEY=your-ai-api-key            # GEMINI_API_KEY の代わりに使用可（優先される）
# AI_BASE_URL=https://...               # OpenAI 互換エンドポイントを差し替える場合のみ
# AI_MODEL=gemini-2.0-flash             # 未設定時のデフォルト: Workers AI バインディング使用時は @cf/qwen/qwen3-30b-a3b-fp8、それ以外は gemini-2.0-flash

# 外部 API キー（サーバー側専用 / ブラウザに露出させない）
# フェーズ4で使用
# RAKUTEN_APP_ID=your-rakuten-app-id
# RAKUTEN_ACCESS_KEY=your-rakuten-access-key
# TMDB_API_KEY=your-tmdb-api-key
# WATCHMODE_API_KEY=your-watchmode-api-key
# WATCHMODE_API_BASE_URL=https://api.watchmode.com/v1
