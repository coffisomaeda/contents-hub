if git diff --cached --name-only | grep -q 'frontend/wrangler.jsonc'; then
  echo "wrangler.jsonc が変更されたため、型定義を再生成中..."
  pnpm --filter frontend exec wrangler types
  git add frontend/worker-configuration.d.ts
fi

if git diff --cached --name-only | grep -q '^supabase/migrations/.*\.sql$'; then
  echo "SQLマイグレーションの変更を検知。Supabaseの型定義を再生成中..."
  if supabase status &>/dev/null; then
    pnpm --filter frontend run gen:types
    pnpm --filter frontend run format
    git add frontend/src/lib/types/supabase.ts
  else
    echo "警告: Supabaseローカル環境が起動していないため、型定義の自動生成をスキップ。"
  fi
fi


pnpm exec lint-staged

if git diff --cached --name-only | grep -q '^frontend/src/'; then
  echo "フロントエンドのコード変更を検知。重複コード（jscpd）をチェック中..."
  pnpm -F frontend run jscpd
fi
